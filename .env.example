# Copy to .env for local development. Never commit real secrets.

# --- Shared ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Persistence (docker-compose defaults) ---
POSTGRES_DSN=postgresql+asyncpg://nexus:nexus@localhost:5432/nexusquant
REDIS_URL=redis://localhost:6379/0

# --- Security (SPEC-005 §11) ---
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
EVENT_SIGNING_KEY=change-me-in-production

# --- Event Fabric (SPEC-005 §9) ---
EVENT_RETENTION_DAYS=365
MAX_RETRY_COUNT=5
WEBSOCKET_HEARTBEAT=30
REPLAY_BATCH_SIZE=500

# --- Real market data (optional): DhanHQ v2 free API ---
# Leave BLANK to use the built-in synthetic feed. To get REAL NSE data:
#   1) open a free account at dhan.co, 2) generate an access token in the DhanHQ
#      Trading APIs section, 3) paste your Client ID + token below.
# The app never logs in for you; it only reads these values. Live quotes flow only
# during market hours (Mon-Fri 09:15-15:30 IST).
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
